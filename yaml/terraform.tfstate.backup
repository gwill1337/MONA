            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "global:\r\n  namespace: mona\r\n  # Метрики физического ПК: IP/hostname должны быть доступны ИЗ ПОДА Prometheus (firewall, маршрутизация).\r\n  # На ПК: node_exporter (или windows_exporter) слушает 0.0.0.0:port.\r\n  externalPcExporter:\r\n    host: \"10.0.0.7\"\r\n    port: 9100\r\n    jobName: \"external-pc-node-exporter\"\r\n\r\nimages:\r\n  fastapi:\r\n    repository: gwill1337/mona-fastapi\r\n    tag: latest\r\n    pullPolicy: Always\r\n  celery:\r\n    repository: gwill1337/mona-celery\r\n    tag: latest\r\n    pullPolicy: Always\r\n  postgres:\r\n    repository: postgres\r\n    tag: \"16\"\r\n    pullPolicy: IfNotPresent\r\n  redis:\r\n    repository: redis\r\n    tag: \"7\"\r\n    pullPolicy: IfNotPresent\r\n  prometheus:\r\n    repository: prom/prometheus\r\n    tag: latest\r\n    pullPolicy: IfNotPresent\r\n\r\nfastapi:\r\n  replicas: 1\r\n  service:\r\n    type: NodePort\r\n    port: 80\r\n    targetPort: 80\r\n    nodePort: 30080\r\n  resources:\r\n    requests: { cpu: \"100m\", memory: \"128Mi\" }\r\n    limits: { cpu: \"500m\", memory: \"512Mi\" }\r\n\r\nceleryWorker:\r\n  replicas: 1\r\n  command: [\"celery\", \"-A\", \"celery_conf.app\", \"worker\", \"--loglevel=info\"]\r\n  resources:\r\n    requests: { cpu: \"100m\", memory: \"128Mi\" }\r\n    limits: { cpu: \"500m\", memory: \"512Mi\" }\r\n\r\nceleryBeat:\r\n  replicas: 1\r\n  command: [\"celery\", \"-A\", \"celery_conf.app\", \"beat\", \"--loglevel=info\"]\r\n  resources:\r\n    requests: { cpu: \"100m\", memory: \"128Mi\" }\r\n    limits: { cpu: \"500m\", memory: \"512Mi\" }\r\n\r\npostgres:\r\n  service:\r\n    port: 5432\r\n  auth:\r\n    user: myuser\r\n    db: mydb\r\n    # Backwards-compatible keys expected by templates\r\n    username: myuser\r\n    database: mydb\r\n  persistence:\r\n    enabled: true\r\n    size: 1Gi\r\n  resources:\r\n    requests: { cpu: \"250m\", memory: \"256Mi\" }\r\n    limits: { cpu: \"500m\", memory: \"512Mi\" }\r\n\r\nredis:\r\n  service:\r\n    port: 6379\r\n  persistence:\r\n    enabled: true\r\n    # hostPath для локалки, в prod лучше PVC\r\n    hostPath: /data/redisdata\r\n  resources:\r\n    requests: { cpu: \"250m\", memory: \"256Mi\" }\r\n    limits: { cpu: \"500m\", memory: \"512Mi\" }\r\n\r\n# Отдельный Prometheus (только chart mona): ПК + SD нод/подов. Не пересекается по именам с kube-prometheus-stack.\r\nprometheus:\r\n  enabled: true\r\n  replicas: 1\r\n  service:\r\n    type: NodePort\r\n    port: 9090\r\n    targetPort: 9090\r\n    nodePort: 30091\r\n  resources:\r\n    requests: { cpu: \"100m\", memory: \"256Mi\" }\r\n    limits: { cpu: \"500m\", memory: \"1Gi\" }\r\n\r\nmonitoring:\r\n  enabled: true\r\n\r\nkube-prometheus-stack:\r\n  grafana:\r\n    enabled: true\r\n    service:\r\n      type: NodePort\r\n      nodePort: 30300\r\n    adminPassword: \"admin123\"\r\n    sidecar:\r\n      dashboards:\r\n        enabled: true\r\n        label: grafana_dashboard\r\n        searchNamespace: mona\r\n    dashboardProviders:\r\n      dashboardproviders.yaml:\r\n        apiVersion: 1\r\n        providers:\r\n          - name: default\r\n            orgId: 1\r\n            folder: \"\"\r\n            type: file\r\n            disableDeletion: false\r\n            editable: true\r\n            options:\r\n              path: /var/lib/grafana/dashboards/default\r\n    datasources:\r\n      datasources.yaml:\r\n        apiVersion: 1\r\n        datasources:\r\n          - name: Prometheus\r\n            type: prometheus\r\n            access: proxy\r\n            url: http://mona-kube-prometheus-stack-prometheus.mona.svc:9090\r\n            isDefault: false\r\n          - name: Prometheus-PC\r\n            type: prometheus\r\n            access: proxy\r\n            url: http://prometheus-main-metrics.mona.svc:9090\r\n            isDefault: false\r\n  prometheus:\r\n    enabled: true\r\n  # Внешний ПК скрейпится отдельным prometheus-main-metrics (templates/prometheus-*.yaml).\r\n  nodeExporter:\r\n    enabled: true",
              "postgres:\r\n  auth:\r\n    user: myuser\r\n    password: \"1234\"\r\n    db: mydb"
            ],
            "verify": false,
            "version": "0.1.0",
            "wait": true,
            "wait_for_jobs": false
          },
