            "metadata": [
              {
                "app_version": "1.16.0",
                "chart": "mona-chart",
                "first_deployed": 1781987335,
                "last_deployed": 1781987335,
                "name": "mona",
                "namespace": "mona",
                "notes": "kube-state-metrics is a simple service that listens to the Kubernetes API server and generates metrics about the state of the objects.\nThe exposed metrics can be found here:\nhttps://github.com/kubernetes/kube-state-metrics/blob/master/docs/README.md#exposed-metrics\n\nThe metrics are exported on the HTTP endpoint /metrics on the listening port.\nIn your case, mona-kube-state-metrics.mona.svc.cluster.local:8080/metrics\n\nThey are served either as plaintext or protobuf depending on the Accept header.\nThey are designed to be consumed either by Prometheus itself or by a scraper that is compatible with scraping a Prometheus client endpoint.\n\n1. Get your 'admin' user password by running:\n\n   kubectl get secret --namespace mona mona-grafana -o jsonpath=\"{.data.admin-password}\" | base64 --decode ; echo\n\n\n2. The Grafana server can be accessed via port 80 on the following DNS name from within your cluster:\n\n   mona-grafana.mona.svc.cluster.local\n\n   Get the Grafana URL to visit by running these commands in the same shell:\n     export NODE_PORT=$(kubectl get --namespace mona -o jsonpath=\"{.spec.ports[0].nodePort}\" services mona-grafana)\n     export NODE_IP=$(kubectl get nodes --namespace mona -o jsonpath=\"{.items[0].status.addresses[0].address}\")\n     echo http://$NODE_IP:$NODE_PORT\n\n3. Login with the password from step 1 and the username: admin\n#################################################################################\n######   WARNING: Persistence is disabled!!! You will lose your data when   #####\n######            the Grafana pod is terminated.                            #####\n#################################################################################\n\n1. Get the application URL by running these commands:\n  export POD_NAME=$(kubectl get pods --namespace mona -l \"app.kubernetes.io/name=prometheus-node-exporter,app.kubernetes.io/instance=mona\" -o jsonpath=\"{.items[0].metadata.name}\")\n  echo \"Visit http://127.0.0.1:9100 to use your application\"\n  kubectl port-forward --namespace mona $POD_NAME 9100\nkube-prometheus-stack has been installed. Check its status by running:\n  kubectl --namespace mona get pods -l \"release=mona\"\n\nGet Grafana 'admin' user password by running:\n\n  kubectl --namespace mona get secrets mona-grafana -o jsonpath=\"{.data.admin-password}\" | base64 -d ; echo\n\nAccess Grafana local instance:\n\n  export POD_NAME=$(kubectl --namespace mona get pod -l \"app.kubernetes.io/name=grafana,app.kubernetes.io/instance=mona\" -oname)\n  kubectl --namespace mona port-forward $POD_NAME 3000\n\nGet your grafana admin user password by running:\n\n  kubectl get secret --namespace mona -l app.kubernetes.io/component=admin-secret -o jsonpath=\"{.items[0].data.admin-password}\" | base64 --decode ; echo\n\n\nVisit https://github.com/prometheus-operator/kube-prometheus for instructions on how to create \u0026 configure Alertmanager and Prometheus instances using the Operator.\n",
                "revision": 1,
                "values": "{\"celeryBeat\":{\"command\":[\"celery\",\"-A\",\"celery_conf.app\",\"beat\",\"--loglevel=info\"],\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"128Mi\"}}},\"celeryWorker\":{\"command\":[\"celery\",\"-A\",\"celery_conf.app\",\"worker\",\"--loglevel=info\"],\"env\":{\"DATABASE_URL\":\"(sensitive value)\"},\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"128Mi\"}}},\"fastapi\":{\"env\":{\"DATABASE_URL\":\"(sensitive value)\"},\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"128Mi\"}},\"service\":{\"nodePort\":30080,\"port\":80,\"targetPort\":80,\"type\":\"NodePort\"}},\"global\":{\"externalPcExporter\":{\"host\":\"10.0.0.7\",\"jobName\":\"external-pc-node-exporter\",\"port\":9100},\"namespace\":\"mona\"},\"images\":{\"celery\":{\"pullPolicy\":\"Always\",\"repository\":\"gwill1337/mona-celery\",\"tag\":\"latest\"},\"fastapi\":{\"pullPolicy\":\"Always\",\"repository\":\"gwill1337/mona-fastapi\",\"tag\":\"latest\"},\"postgres\":{\"pullPolicy\":\"IfNotPresent\",\"repository\":\"postgres\",\"tag\":\"16\"},\"prometheus\":{\"pullPolicy\":\"IfNotPresent\",\"repository\":\"prom/prometheus\",\"tag\":\"latest\"},\"redis\":{\"pullPolicy\":\"IfNotPresent\",\"repository\":\"redis\",\"tag\":\"7\"}},\"kube-prometheus-stack\":{\"grafana\":{\"adminPassword\":\"admin123\",\"dashboardProviders\":{\"dashboardproviders.yaml\":{\"apiVersion\":1,\"providers\":[{\"disableDeletion\":false,\"editable\":true,\"folder\":\"\",\"name\":\"default\",\"options\":{\"path\":\"/var/lib/grafana/dashboards/default\"},\"orgId\":1,\"type\":\"file\"}]}},\"datasources\":{\"datasources.yaml\":{\"apiVersion\":1,\"datasources\":[{\"access\":\"proxy\",\"isDefault\":false,\"name\":\"Prometheus\",\"type\":\"prometheus\",\"url\":\"http://mona-kube-prometheus-stack-prometheus.mona.svc:9090\"},{\"access\":\"proxy\",\"isDefault\":false,\"name\":\"Prometheus-PC\",\"type\":\"prometheus\",\"url\":\"http://prometheus-main-metrics.mona.svc:9090\"}]}},\"enabled\":true,\"service\":{\"nodePort\":30300,\"type\":\"NodePort\"},\"sidecar\":{\"dashboards\":{\"enabled\":true,\"label\":\"grafana_dashboard\",\"searchNamespace\":\"mona\"}}},\"nodeExporter\":{\"enabled\":true},\"prometheus\":{\"enabled\":true}},\"monitoring\":{\"enabled\":true},\"postgres\":{\"auth\":{\"database\":\"mydb\",\"db\":\"mydb\",\"password\":\"(sensitive value)\",\"user\":\"myuser\",\"username\":\"myuser\"},\"persistence\":{\"enabled\":true,\"size\":\"1Gi\"},\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"250m\",\"memory\":\"256Mi\"}},\"service\":{\"port\":5432}},\"prometheus\":{\"enabled\":true,\"replicas\":1,\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"1Gi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}},\"service\":{\"nodePort\":30091,\"port\":9090,\"targetPort\":9090,\"type\":\"NodePort\"}},\"redis\":{\"persistence\":{\"enabled\":true,\"hostPath\":\"/data/redisdata\"},\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"250m\",\"memory\":\"256Mi\"}},\"service\":{\"port\":6379}}}",
                "version": "0.1.0"
              }
            ],
